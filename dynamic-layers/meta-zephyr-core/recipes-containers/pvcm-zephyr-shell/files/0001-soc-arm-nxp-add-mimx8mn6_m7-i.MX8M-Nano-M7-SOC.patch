+# i.MX8MN M7 SoC series
+
+# Copyright (c) 2024-2026 Pantacor Ltd.
+# SPDX-License-Identifier: Apache-2.0
+
+choice
+prompt "i.MX8MN M7 Selection"
+depends on SOC_SERIES_IMX8MN_M7
+
+config SOC_MIMX8MN6
+	bool "SOC_MIMX8MN6"
