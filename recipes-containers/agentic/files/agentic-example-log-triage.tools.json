                "properties": {
                    "severity": {
                        "type": "string",
                        "description": "One of: critical, warn, info, ignore."
                    },
                    "notify": {
                        "type": "boolean",
                        "description": "True if a human should be alerted."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Short one-line justification, max 120 chars."
                    }
                }
            }
        }
    }
]
