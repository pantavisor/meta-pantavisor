    "groups": [
        { "name": "root", "restart_policy": "system", "status_goal": "STARTED" },
        { "name": "platform", "restart_policy": "system", "status_goal": "STARTED" },
        { "name": "app", "restart_policy": "container", "status_goal": "STARTED" }
    ]
