#!/bin/sh

set -e

targetdir=$1

m=`ls kas/machines/*`
configsuffix=:.github/configs/build-base-starter.yaml

create_push_workflows() {

	yocto_branch=$1
	shift
	machines=$@

	echo "new push workflow for: $m"
	cat > .github/workflows/onpush-$yocto_branch-$m.yaml << EOF1

name: 'Onpush - $m-$yocto_branch'

on:
  push:
    paths:
      - '**'
      - '.github/configs/**'
      - '!.github/scripts/**'
      - '!.github/workflows/updatemachines.yaml'

jobs:

  build-$m-$yocto_branch:
    uses: ./.github/workflows/buildkas-starter.yaml
    with:
      configs: .github/configs/release/$m-$yocto_branch.yaml:.github/configs/shared-vols.yaml
      machine_name: $m-$yocto_branch
    secrets: inherit
EOF1
}

create_schedule_workflows() {

	yocto_branch=$1
	shift 2
	machines=$@

	echo "new scheadule workflow for: $m"
    cat > .github/workflows/schedule-$yocto_branch-$m.yaml << EOF1
name: 'Schedule - $m-$yocto_branch'

on:
  workflow_dispatch:
  schedule:
   - cron: "30 0 * * *"

jobs:

  build-$m-$yocto_branch:
    uses: ./.github/workflows/buildkas-starter.yaml
    with:
      configs: .github/configs/release/$m-$yocto_branch.yaml:.github/configs/shared-vols.yaml
      machine_name: $m-$yocto_branch
    secrets: inherit
EOF1
}


create_machines() {

	yocto_branch=$1
	make_workflow=$2

	shift 2
	configs=$@

	echo "$yocto_branch - processing push configs:
	$configs"


	for cc in $configs; do
		echo CC: $cc
		m=`echo $cc | sed 's/.*machines.//;s/.yaml:.*//'`
		KAS_WORK_DIR=. kas dump --update --resolve-refs "kas/sourcedir.yaml:$cc" > .github/configs/release/$m-$yocto_branch.yaml

	    $make_workflow $yocto_branch $m
	done
}


yocto_branch=scarthgap

all_machines=" \
	kas/machines/sunxi-orange-pi-3lts.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
	kas/machines/sunxi-orange-pi-r1.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
	kas/machines/sunxi-bananapi-m2-berry.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
	kas/machines/imx8qxp-b0-mek.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml:kas/scarthgap-nxp.yaml$configsuffix \
	kas/machines/raspberrypi-armv8.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
	kas/machines/colibri-imx6ull.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
	kas/machines/radxa-rock5a.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
"

onpush_machines=" \
	kas/machines/sunxi-bananapi-m2-berry.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
	kas/machines/raspberrypi-armv8.yaml:kas/bsp-base.yaml:kas/$yocto_branch.yaml$configsuffix \
"

rm -f .github/configs/release/*-$yocto_branch.yaml*
rm -f .github/workflows/onpush*
rm -f .github/workflows/schedule*


create_machines $yocto_branch create_push_workflows  $onpush_machines
create_machines $yocto_branch create_schedule_workflows  $all_machines


#git add .github/configs/release/
#
#echo DIFF:
#git diff HEAD .github/

