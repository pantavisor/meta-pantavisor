#!/bin/bash

set -e

YOCTO_BRANCH=$(jq -r .yocto_branch .github/machines.json)


rm -f .github/workflows/tag-$YOCTO_BRANCH*
rm -f .github/workflows/manual-$YOCTO_BRANCH*
rm -f .github/workflows/onpush-$YOCTO_BRANCH*

.github/scripts/make-manual-dispatch.py
.github/scripts/make-tag-matrix.py
.github/scripts/make-onpush-matrix.py
.github/scripts/update-readme-board.py

echo "All workflows generated successfully!"
