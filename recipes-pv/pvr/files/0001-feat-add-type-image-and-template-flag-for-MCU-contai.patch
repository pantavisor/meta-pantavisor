+
+package templates
+
+const (
+	MCU_RUN_JSON = `{{ "" -}}
+{
+	"#spec": "service-manifest-run@1",
+	"name":"{{- .Source.name -}}",
+	"type": "mcu",
+	"mcu": {
+		"device": "{{- .Source.args.PV_MCU_DEVICE | pvr_ifNull .Source.name -}}"
+		{{- if .Source.args.PV_MCU_TRANSPORT -}}
+		,"transport": "{{- .Source.args.PV_MCU_TRANSPORT -}}"
+		{{- end -}}
+		{{- if .Source.args.PV_MCU_BAUDRATE -}}
+		,"baudrate": {{- .Source.args.PV_MCU_BAUDRATE -}}
+		{{- end -}}
+		{{- if .Source.args.PV_MCU_REMOTEPROC -}}
+		,"remoteproc": "{{- .Source.args.PV_MCU_REMOTEPROC -}}"
+		{{- end }}
+	},
+	{{- if .Source.args.PV_MCU_FIRMWARE }}
+	"firmware": "{{- .Source.args.PV_MCU_FIRMWARE -}}",
+	{{- end }}
+	"drivers": {
+		"manual": {{- if .Source.args.PV_DRIVERS_MANUAL }} {{ sprig_toJson .Source.args.PV_DRIVERS_MANUAL -}}{{- else }}[]{{- end }},
+		"required": {{- if .Source.args.PV_DRIVERS_REQUIRED }} {{ sprig_toJson .Source.args.PV_DRIVERS_REQUIRED -}}{{- else }}[]{{- end }},
+		"optional": {{- if .Source.args.PV_DRIVERS_OPTIONAL }} {{ sprig_toJson .Source.args.PV_DRIVERS_OPTIONAL -}}{{- else }}[]{{- end }}
+	},
+	"services": {
+		"manual": {{- if .Source.args.PV_SERVICES_MANUAL }} {{ sprig_toJson .Source.args.PV_SERVICES_MANUAL -}}{{- else }}[]{{- end }},
+		"required": {{- if .Source.args.PV_SERVICES_REQUIRED }} {{ sprig_toJson .Source.args.PV_SERVICES_REQUIRED -}}{{- else }}[]{{- end }},
+		"optional": {{- if .Source.args.PV_SERVICES_OPTIONAL }} {{ sprig_toJson .Source.args.PV_SERVICES_OPTIONAL -}}{{- else }}[]{{- end }}
+	},
+	{{- if .Source.args.PV_AUTO_RECOVERY }}
+	"auto_recovery": {{- sprig_toPrettyJson .Source.args.PV_AUTO_RECOVERY | pvr_jsonIndent 0 1 "\t" -}}{{- "," -}}
+	{{- else if .Source.args.PV_AUTO_RECOVERY_POLICY }}
+	"auto_recovery": {
+		"policy": "{{- .Source.args.PV_AUTO_RECOVERY_POLICY -}}"
+		{{- if .Source.args.PV_AUTO_RECOVERY_MAX_RETRIES -}}
+		,"max_retries": {{- .Source.args.PV_AUTO_RECOVERY_MAX_RETRIES -}}
+		{{- end -}}
+		{{- if .Source.args.PV_AUTO_RECOVERY_RETRY_DELAY -}}
+		,"retry_delay": {{- .Source.args.PV_AUTO_RECOVERY_RETRY_DELAY -}}
+		{{- end -}}
+		{{- if .Source.args.PV_AUTO_RECOVERY_BACKOFF_FACTOR -}}
+		,"backoff_factor": {{- .Source.args.PV_AUTO_RECOVERY_BACKOFF_FACTOR -}}
+		{{- end -}}
+		{{- if .Source.args.PV_AUTO_RECOVERY_RESET_WINDOW -}}
+		,"reset_window": {{- .Source.args.PV_AUTO_RECOVERY_RESET_WINDOW -}}
+		{{- end }}
+	},
+	{{- end }}
+	{{- if .EffectiveGroup }}
+	"group": "{{- .EffectiveGroup }}",
+	{{- end }}
+	{{- if .Source.args.PV_RESTART_POLICY }}
+	"restart_policy": "{{- .Source.args.PV_RESTART_POLICY }}",
+	{{- end }}
+	{{- if .Source.args.PV_STATUS_GOAL }}
+	"status_goal": "{{- .Source.args.PV_STATUS_GOAL }}",
+	{{- end }}
+	"storage": {}
+}
+`
+)
+
+func BuiltinMcuHandler(values map[string]interface{}) (files map[string][]byte, err error) {
+	files = make(map[string][]byte, 1)
+	files["run.json"], err = compileTemplate(MCU_RUN_JSON, values)
+	return
+}
