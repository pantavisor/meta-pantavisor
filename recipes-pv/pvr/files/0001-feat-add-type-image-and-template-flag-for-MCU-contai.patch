+		{{- if .Source.args.PV_AUTO_RECOVERY_BACKOFF_FACTOR -}}
+		,"backoff_factor": {{- .Source.args.PV_AUTO_RECOVERY_BACKOFF_FACTOR -}}
+		{{- end -}}
+		{{- if .Source.args.PV_AUTO_RECOVERY_RESET_WINDOW -}}
+		,"reset_window": {{- .Source.args.PV_AUTO_RECOVERY_RESET_WINDOW -}}
+		{{- end }}
+	},
+	{{- end }}
+	{{- if .EffectiveGroup }}
+	"group": "{{- .EffectiveGroup }}",
+	{{- end }}
+	{{- if .Source.args.PV_RESTART_POLICY }}
+	"restart_policy": "{{- .Source.args.PV_RESTART_POLICY }}",
+	{{- end }}
+	{{- if .Source.args.PV_STATUS_GOAL }}
+	"status_goal": "{{- .Source.args.PV_STATUS_GOAL }}",
+	{{- end }}
+	"storage": {}
+}
+`
+)
+
+func BuiltinMcuHandler(values map[string]interface{}) (files map[string][]byte, err error) {
+	files = make(map[string][]byte, 1)
+	files["run.json"], err = compileTemplate(MCU_RUN_JSON, values)
+	return
+}
