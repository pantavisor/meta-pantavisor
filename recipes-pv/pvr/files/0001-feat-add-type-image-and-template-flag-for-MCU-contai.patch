+// AddImageApp adds a container from a raw image file (e.g. firmware ELF).
+// Unlike rootfs which creates a squashfs, this copies the file as-is.
+func AddImageApp(p *Pvr, app *AppData) error {
+	appPath := filepath.Join(p.Dir, app.Appname)
+
+	imagePath, err := ExpandPath(app.From)
+	if err != nil {
+		return fmt.Errorf("cannot resolve image path: %w", err)
+	}
+
+	fi, err := os.Stat(imagePath)
+	if err != nil {
+		return fmt.Errorf("cannot stat image: %w", err)
+	}
+	if fi.IsDir() {
+		return fmt.Errorf("image path must be a file, not a directory")
+	}
+
+	if app.ForceAdd {
+		RemoveAll(appPath)
+	}
+
+	err = os.MkdirAll(appPath, 0777)
+	if err != nil {
+		return err
+	}
+
+	// Copy image file into container directory
+	imageBaseName := filepath.Base(imagePath)
+	destImage := filepath.Join(appPath, imageBaseName)
+
+	imageData, err := os.ReadFile(imagePath)
+	if err != nil {
+		return fmt.Errorf("cannot read image: %w", err)
+	}
+
+	if err = os.WriteFile(destImage, imageData, 0644); err != nil {
+		return fmt.Errorf("cannot write image: %w", err)
+	}
+
+	// Compute digest
+	imageFile, err := os.Open(destImage)
+	if err != nil {
+		return err
+	}
+	imageDigest, err := digest.FromReader(imageFile)
+	imageFile.Close()
+	if err != nil {
+		return err
+	}
+
+	// Determine template: use app.TemplateOverride if set, else builtin-mcu
+	templateName := TEMPLATE_BUILTIN_MCU
+	if app.TemplateOverride != "" {
+		templateName = app.TemplateOverride
+	}
+
+	config := map[string]interface{}{}
+	if app.ConfigFile != "" {
+		configFile, err := GetDockerConfigFile(p, app)
+		if err != nil {
+			return err
+		}
+		for k, v := range configFile {
+			config[k] = v
+		}
+	}
+	if app.Config != nil {
+		for k, v := range app.Config {
+			config[k] = v
+		}
+	}
+
+	src := Source{
+		Spec:         SRC_SPEC,
+		Template:     templateName,
+		TemplateArgs: app.TemplateArgs,
+		Config:       config,
+		RootFsSource: RootFsSource{
+			RootFsURL:    app.From,
+			RootFsDigest: imageDigest.String(),
+		},
+	}
+
+	srcContent, err := json.MarshalIndent(src, " ", " ")
+	if err != nil {
+		return err
+	}
+
+	srcFilePath := filepath.Join(appPath, SRC_FILE)
+	if err = os.WriteFile(srcFilePath, srcContent, 0644); err != nil {
+		return err
+	}
+
+	app.Appmanifest = &src
+	app.DestinationPath = appPath
+
+	return nil
+}
+
+// InstallImageApp generates template files for an image-based container.
+func InstallImageApp(p *Pvr, app *AppData, appManifest *Source) error {
+	dockerConfig := map[string]interface{}{}
+
+	app.DestinationPath = filepath.Join(p.Dir, app.Appname)
+	err := p.GenerateApplicationTemplateFiles(app.Appname, dockerConfig, appManifest)
+	if err != nil {
+		return err
+	}
+
+	return nil
+}
