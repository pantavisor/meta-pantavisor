+		{{- if .Docker.Cmd }}
+			{{- if pvr_isSlice .Docker.Cmd }}
+				{{- range pvr_sliceFrom .Docker.Cmd 0 }} "{{ . }}"{{ end }}
+			{{- else }}
+				{{- "" }} "{{ .Docker.Cmd }}"
+			{{- end }}
+		{{- end }}
 	{{- end }}
 {{- else }}
