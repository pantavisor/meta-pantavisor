+		},
+	})
+
+	ErrorIf(t, len(result) == 0, "error when compiling template")
+	ErrorIfNot(t, strings.Contains(string(result), "lxc.init.cmd = /usr/bin/myapp \"--flag\" \"value\""), "pattern not found in generated string "+string(result))
+}
