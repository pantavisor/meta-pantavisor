+func testLXCContainerConf__Docker_StringEntrypointStringCmd(t *testing.T) {
+	result, _ := compileTemplate(LXC_CONTAINER_CONF, map[string]interface{}{
+		"name": "container1",
+		"Docker": map[string]interface{}{
+			"Entrypoint": "/usr/bin/myapp",
+			"Cmd":        "--socket=/run/my.sock",
+		},
+	})
+
+	ErrorIf(t, len(result) == 0, "error when compiling template")
+	ErrorIfNot(t, strings.Contains(string(result), "lxc.init.cmd = /usr/bin/myapp \"--socket=/run/my.sock\""), "pattern not found in generated string "+string(result))
+}
+
