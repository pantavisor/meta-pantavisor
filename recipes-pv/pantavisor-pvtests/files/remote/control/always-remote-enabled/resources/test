#!/bin/sh

source /usr/share/pantavisor/pvtest/utils

device_id=$(cat /var/run/pantavisor/pv/device-id)

# Clone both checkouts upfront (remote trail + local device)
pvr clone "https://api.pantahub.com/trails/$device_id" /home/remote > /dev/null 2>&1
pvr clone http://localhost:12368/cgi-bin/pvr /home/local > /dev/null 2>&1

# 1. Post empty remote update (non-reboot → UPDATED)
cd /home/remote
pvr post -m "remote update 1" > /dev/null 2>&1
wait_for_revision_state "pvr-sdk" "1" "UPDATED" \
    || { echo "ERROR: timeout waiting for revision 1 to reach UPDATED" >&2; exit 1; }
pvcontrol steps show-progress 1
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'

# 2. Post empty local update (non-reboot → UPDATED, device enters local mode)
cd /home/local
pvr post --rev "locals/test-303" > /dev/null 2>&1
wait_for_revision_state "pvr-sdk" "locals/test-303" "UPDATED" \
    || { echo "ERROR: timeout waiting for locals/test-303 to reach UPDATED" >&2; exit 1; }
pvcontrol steps show-progress locals/test-303
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'

# 3. Post empty remote update — consumed on its own (PV_CONTROL_REMOTE_ALWAYS=1 keeps Hub comms open)
cd /home/remote
pvr post -m "remote update 2" > /dev/null 2>&1
wait_for_revision_state "pvr-sdk" "2" "UPDATED" \
    || { echo "ERROR: timeout waiting for revision 2 to reach UPDATED" >&2; exit 1; }
pvcontrol steps show-progress 2
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'
