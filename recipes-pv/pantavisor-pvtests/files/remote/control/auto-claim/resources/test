#!/bin/sh

source /usr/share/pantavisor/pvtest/utils
PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" pvr login > /dev/null 2>&1

echo "== reboot so the installed base becomes the running (DONE) revision =="
pvcontrol commands reboot > /dev/null 2>&1
sleep 10
wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120 \
    || { echo "ERROR: timeout waiting for pv-ctrl after reboot" >&2; exit 1; }

echo "== wait for unclaimed state =="
wait_for_value "pvcontrol devmeta ls | jq -r '.\"pantahub.state\"'" "claim" 120 \
    || { echo "ERROR: timeout waiting for pantahub.state claim" >&2; exit 1; }
pvcontrol devmeta ls | jq -M -r '.["pantahub.state"]'

echo "== generate factory autotok via Pantahub API =="
device_id=$(_pv_exec cat /run/pantavisor/pv/device-id)
bearer=$(cat "$HOME/.pvr/auth.json" 2>/dev/null | jq -r 'first(.tokens[]) | .["access-token"] // empty')
autotok_json=$(curl -s -X POST \
	-H "Authorization: Bearer $bearer" \
	-H "Content-Type: application/json" \
	-d '{}' \
	"https://api.pantahub.com/devices/tokens")
autotok=$(echo "$autotok_json" | jq -r '.token')
autotok_id=$(echo "$autotok_json" | jq -r '.id')

echo "== inject autotok and reboot =="
_pv_exec sh -c "echo PH_FACTORY_AUTOTOK=$autotok >> /run/pantavisor/pv/phconfig/pantahub.config"
_pv_exec rm -f /run/pantavisor/pv/phconfig/unclaimed.config
pvcontrol commands reboot > /dev/null 2>&1

echo "== wait for auto-claim =="
wait_for_value "pvcontrol devmeta ls | jq -r '.\"pantavisor.status\"'" "READY" 120 \
    || { echo "ERROR: timeout waiting for pantavisor.status READY after reboot" >&2; exit 1; }
wait_for_value "pvcontrol devmeta ls | jq -r '.\"pantahub.state\"'" "idle" 120 \
    || { echo "ERROR: timeout waiting for pantahub.state idle after auto-claim" >&2; exit 1; }
pvcontrol devmeta ls | jq -M -r '.["pantahub.state"]'

echo "== cleanup =="
if [ -n "$device_id" ]; then
	pvr dev delete -y $device_id
fi
if [ -n "$autotok_id" ]; then
	curl -s -X DELETE \
		-u "$PH_USER:$PH_PASS" \
		"https://api.pantahub.com/devices/tokens/$autotok_id" > /dev/null 2>&1
fi
