#!/bin/sh

source /usr/share/pantavisor/pvtest/utils

device_id=$(_pv_exec cat /run/pantavisor/pv/device-id)

# Per-test isolation: the tester FS and pvr's object cache are shared across
# tests (and concurrent at -p>1), so clone into a per-test temp subdir; never override the
# harness-authenticated $HOME (it holds the Hub login used by pvr post). Clone
# the device's CURRENT state from its local pvr endpoint (a clean baseline) — NOT
# the accumulating Hub trail head — and post revisions explicitly to the trail.
checkout="$(mktemp -d)/checkout"
pvr clone http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr "$checkout" > /dev/null 2>&1 \
    || { echo "ERROR: pvr clone failed" >&2; exit 1; }
cd "$checkout"

trail_url="https://api.pantahub.com/trails/$device_id"

echo "== post large revision (download takes long) =="
dd if=/dev/urandom of=pvr-sdk/bigfile.bin bs=1M count=50 2>/dev/null
pvr add pvr-sdk/bigfile.bin > /dev/null 2>&1
pvr commit -m "add large file to exercise download phase" > /dev/null 2>&1
rev=$(pvr_post_rev -m "trigger retry test" "$trail_url")
[ -n "$rev" ] || { echo "ERROR: could not determine posted revision" >&2; exit 1; }
cloud_step_url="https://api.pantahub.com/trails/$device_id/steps/$rev"

echo "== wait for posted revision to start downloading (retry 1) =="
wait_for_value "pvcontrol steps show-progress $rev | jq -r '.status'" "DOWNLOADING" 120 \
    || { echo "ERROR: timeout waiting for revision $rev to start DOWNLOADING" >&2; exit 1; }
pvcontrol steps show-progress $rev | jq -Mc 'del(.logs, .downloads)'

echo "== kill PV (crash 1, triggers retry 2) =="
crash_pv
wait_for_value "pvcontrol devmeta ls | jq -r '.\"pantavisor.status\"'" "READY" 120 \
    || { echo "ERROR: timeout waiting for pantavisor.status READY after kill (1)" >&2; exit 1; }
wait_for_value "pvcontrol steps show-progress $rev | jq -r '.retries'" "2" 120 \
    || { echo "ERROR: timeout waiting for revision $rev retries to reach 2" >&2; exit 1; }
pvcontrol steps show-progress $rev | jq -Mc 'del(.logs, .downloads)'

echo "== kill PV (crash 2, triggers WONTGO via cloud) =="
crash_pv
wait_for_value "pvcontrol devmeta ls | jq -r '.\"pantavisor.status\"'" "READY" 120 \
    || { echo "ERROR: timeout waiting for pantavisor.status READY after kill (2)" >&2; exit 1; }

echo "== cloud step status after max retries =="
wait_for_value "pvr stepinfo $cloud_step_url 2>/dev/null | sed -n '/^{/,\$p' | jq -r '.progress.status // empty'" "WONTGO" 60 \
    || { echo "ERROR: timeout waiting for cloud to reflect WONTGO" >&2; exit 1; }
pvr stepinfo "$cloud_step_url" | sed -n '/^{/,$p' | jq -M '{status: .progress.status, "status-msg": .progress."status-msg", retries: .progress.retries}'
