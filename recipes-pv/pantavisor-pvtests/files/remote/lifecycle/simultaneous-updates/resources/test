#!/bin/sh

source /usr/share/pantavisor/pvtest/utils

device_id=$(_pv_exec cat /run/pantavisor/pv/device-id)

# Per-test isolation: clone into a temp checkout dir; never override $HOME (see
# automated-workflow.md § Test authoring rules).
checkout="$(mktemp -d)/checkout"
pvr clone http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr "$checkout" > /dev/null 2>&1 \
    || { echo "ERROR: pvr clone failed" >&2; exit 1; }
cd "$checkout"
trail_url="https://api.pantahub.com/trails/$device_id"

echo "== post 3 revisions simultaneously =="
rev1=$(pvr_post_rev -m "first revision" "$trail_url")
rev2=$(pvr_post_rev -m "second revision" "$trail_url")
rev3=$(pvr_post_rev -m "third revision" "$trail_url")
{ [ -n "$rev1" ] && [ -n "$rev2" ] && [ -n "$rev3" ]; } \
    || { echo "ERROR: could not determine posted revisions" >&2; exit 1; }

echo "== first revision =="
# Settle on show-progress reporting UPDATED itself, not just platform state (can lag
# briefly on 3 back-to-back posts); strip volatile logs/downloads for a stable diff.
wait_for_value "pvcontrol steps show-progress $rev1 | jq -r '.status'" "UPDATED" 60 \
    || { echo "ERROR: timeout waiting for show-progress $rev1 = UPDATED" >&2; exit 1; }
pvcontrol steps show-progress $rev1 | jq -Mc 'del(.logs, .downloads)'
echo "== second revision =="
wait_for_value "pvcontrol steps show-progress $rev2 | jq -r '.status'" "UPDATED" 60 \
    || { echo "ERROR: timeout waiting for show-progress $rev2 = UPDATED" >&2; exit 1; }
pvcontrol steps show-progress $rev2 | jq -Mc 'del(.logs, .downloads)'
echo "== third revision =="
wait_for_value "pvcontrol steps show-progress $rev3 | jq -r '.status'" "UPDATED" 60 \
    || { echo "ERROR: timeout waiting for show-progress $rev3 = UPDATED" >&2; exit 1; }
pvcontrol steps show-progress $rev3 | jq -Mc 'del(.logs, .downloads)'
