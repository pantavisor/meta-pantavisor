#!/bin/sh
#
# Hosted D-Bus system bus end-to-end with a real daemon (avahi).
#
# pv-avahi (role "avahi-service", owns org.freedesktop.Avahi, allow
# ["operator","monitor"]) runs avahi-daemon with enable-dbus=yes against the
# pantavisor-hosted bus. The consumer pv-avahi-browse (role "monitor") reaches
# avahi's D-Bus API over the injected bus socket. Neither container ships a
# dbus-daemon, policy XML or /etc/passwd: the bus is hosted by pantavisor and
# the policy is generated from the owns/allow declaration.
#
# A successful Server.GetVersionString / GetHostName roundtrip proves the whole
# chain: avahi claimed its well-known name under the generated policy, the proxy
# masqueraded the monitor caller to its role's numeric uid, and the policy
# granted that uid send access to org.freedesktop.Avahi. The default-deny probe
# then proves an allowed caller still cannot own an arbitrary name.

ADDR="unix:path=/run/dbus/system_bus_socket"
SVC="org.freedesktop.Avahi"
OBJ="/"
IFACE="org.freedesktop.Avahi.Server"

dsend() {
	# run dbus-send inside the consumer container against the injected bus
	# socket. Exec dbus-send directly (via env for the address) rather than
	# through "sh -c": under pventer a busybox "sh -c" wrapper swallows
	# dbus-send's stdout, so the reply would be lost.
	# shellcheck disable=SC2086
	pventer -c "pv-avahi-browse" \
		env DBUS_SYSTEM_BUS_ADDRESS="$ADDR" \
		dbus-send --system --print-reply $* 2>&1
}

# Wait for avahi-daemon to claim org.freedesktop.Avahi on the hosted bus.
i=0
while [ $i -lt 30 ]; do
	if dsend "--dest=org.freedesktop.DBus /org/freedesktop/DBus org.freedesktop.DBus.NameHasOwner string:$SVC" \
		| grep -q "boolean true"; then
		break
	fi
	sleep 1
	i=$((i + 1))
done

echo "== avahi owns $SVC on the hosted bus =="
dsend "--dest=org.freedesktop.DBus /org/freedesktop/DBus org.freedesktop.DBus.NameHasOwner string:$SVC" \
	| grep -o "boolean true"

echo "== monitor roundtrip: Server.GetVersionString (masquerade + policy allow) =="
if dsend "--dest=$SVC $OBJ $IFACE.GetVersionString" | grep -q 'string "avahi'; then
	echo "monitor GetVersionString: OK"
else
	echo "monitor GetVersionString: FAILED"
fi

echo "== monitor roundtrip: Server.GetHostName =="
if dsend "--dest=$SVC $OBJ $IFACE.GetHostName" | grep -qE 'string "[^"]+"'; then
	echo "monitor GetHostName: OK"
else
	echo "monitor GetHostName: FAILED"
fi

echo "== default-deny: monitor may not own a well-known name =="
if dsend "--dest=org.freedesktop.DBus /org/freedesktop/DBus org.freedesktop.DBus.RequestName string:org.pantavisor.Rogue uint32:0" \
	| grep -qE "AccessDenied|not allowed to own"; then
	echo "monitor RequestName: DENIED"
else
	echo "monitor RequestName: ALLOWED (unexpected)"
fi
