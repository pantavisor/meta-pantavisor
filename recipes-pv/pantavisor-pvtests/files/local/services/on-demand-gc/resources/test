#!/bin/sh

source /usr/share/pantavisor/pvtest/utils

# present/absent check for a path inside the pvr-sdk container (which has
# /storage bind-mounted); used to assert GC removed factory + unreferenced objs.
exists() { pventer -c pvr-sdk ls -d "$1" > /dev/null 2>&1 && echo present || echo absent; }

echo "== initial revision =="
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'
# Per-test private HOME + checkout dir: the tester is shared and runs tests
# concurrently at -p>1, so a fixed /home/checkout and pvr's global object cache
# ($HOME/.pvr/objects) race between tests. Use an isolated HOME so this test's
# pvr clone/add/commit/post and checkout cannot collide with other tests.
export HOME="$(mktemp -d)"
pvr clone http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr "$HOME/checkout" > /dev/null 2>&1
cd "$HOME/checkout"

echo "== post reboot update =="
sed -i 's/lxc\.tty\.max = 8/lxc.tty.max = 4/g' pvr-sdk/lxc.container.conf
pvr add .
pvr commit > /dev/null 2>&1
pvr post --rev "locals/done" > /dev/null 2>&1

wait_for_revision_state "pvr-sdk" "locals/done" "DONE" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for locals/done to reach DONE" >&2; exit 1; }
echo "== locals/done: DONE =="
pvcontrol steps show-progress locals/done
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'

echo "== post non-reboot update =="
sed -i 's/lxc\.tty\.max = 8/lxc.tty.max = 4/g' pv-example-app/lxc.container.conf
pvr add .
pvr commit > /dev/null 2>&1
pvr post --rev "locals/updated" > /dev/null 2>&1

wait_for_revision_state "pvr-sdk" "locals/updated" "UPDATED" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for locals/updated to reach UPDATED" >&2; exit 1; }
echo "== locals/updated: UPDATED =="
pvcontrol steps show-progress locals/updated
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'

echo "== storage before GC =="
# No reset between tests: a full /storage listing is not deterministic (other
# tests' revs, containers and logs accumulate). Assert only paths that are
# reliably present here and removed by GC: the factory trail (trails/0, the GC
# target nothing else removes) and the factory pvr-sdk object (only referenced
# by the factory revision). logs/0 and other unreferenced objects are still
# asserted gone by the wait_for_path block after GC below.
echo "factory trail (trails/0):  $(exists /storage/trails/0)"
echo "factory pvr-sdk object:    $(exists /storage/objects/2ef57a87c9044d9c828ed4efc9bff8fd67fa15b00abad6cb607f7ca3d47c1df8)"

echo "== run garbage collector =="
pvcontrol commands run-gc
wait_for_path "pvr-sdk" "/storage/logs/0" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for /storage/logs/0 to disappear" >&2; exit 1; }
wait_for_path "pvr-sdk" "/storage/trails/0" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for /storage/trails/0 to disappear" >&2; exit 1; }
wait_for_path "pvr-sdk" "/storage/objects/e5ee4b76420bf4d317221f081618eba2e68ab97d1b31a5fcfe6ce48b91e8562c" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for object e5ee4b76 to be GC'd" >&2; exit 1; }
wait_for_path "pvr-sdk" "/storage/objects/2ef57a87c9044d9c828ed4efc9bff8fd67fa15b00abad6cb607f7ca3d47c1df8" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for object 2ef57a87 to be GC'd" >&2; exit 1; }

echo "== storage after GC =="
echo "factory trail (trails/0):  $(exists /storage/trails/0)"
echo "factory pvr-sdk object:    $(exists /storage/objects/2ef57a87c9044d9c828ed4efc9bff8fd67fa15b00abad6cb607f7ca3d47c1df8)"
