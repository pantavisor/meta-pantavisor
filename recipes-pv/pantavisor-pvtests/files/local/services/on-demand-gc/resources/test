#!/bin/sh

source /usr/share/pantavisor/pvtest/utils

# initial setup
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'
pvr clone http://localhost:12368/cgi-bin/pvr /home/checkout > /dev/null 2>&1
cd /home/checkout

# post a new change that triggers a reboot update
sed -i 's/lxc\.tty\.max = 8/lxc.tty.max = 4/g' pvr-sdk/lxc.container.conf
pvr add .
pvr commit > /dev/null 2>&1
pvr post --rev "locals/done" > /dev/null 2>&1

# after posting evaluation
wait_for_revision_state "pvr-sdk" "locals/done" "DONE" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for locals/done to reach DONE" >&2; exit 1; }
pvcontrol steps show-progress locals/done
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'

# post a new change that triggers a non-reboot update
sed -i 's/lxc\.tty\.max = 8/lxc.tty.max = 4/g' pv-example-app/lxc.container.conf
pvr add .
pvr commit > /dev/null 2>&1
pvr post --rev "locals/updated" > /dev/null 2>&1

# after posting evaluation
wait_for_revision_state "pvr-sdk" "locals/updated" "UPDATED" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for locals/updated to reach UPDATED" >&2; exit 1; }
pvcontrol steps show-progress locals/updated
pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]'

# run garbage collector, compare before and after
OBJ_COUNT=$(pventer -c pvr-sdk find /storage/objects -mindepth 1 -maxdepth 1 | wc -l)
pventer -c pvr-sdk find /storage -not -name console.log | grep -v '^/storage/objects/[0-9a-f]' | sort
echo "object count: $OBJ_COUNT"
pvcontrol commands run-gc
wait_for_path "pvr-sdk" "/storage/logs/0" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for /storage/logs/0 to disappear" >&2; exit 1; }
wait_for_path "pvr-sdk" "/storage/trails/0" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for /storage/trails/0 to disappear" >&2; exit 1; }
wait_for_path "pvr-sdk" "/storage/objects/e5ee4b76420bf4d317221f081618eba2e68ab97d1b31a5fcfe6ce48b91e8562c" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for object e5ee4b76 to be GC'd" >&2; exit 1; }
wait_for_path "pvr-sdk" "/storage/objects/2ef57a87c9044d9c828ed4efc9bff8fd67fa15b00abad6cb607f7ca3d47c1df8" "-d" > /dev/null 2>&1 \
    || { echo "ERROR: timeout waiting for object 2ef57a87 to be GC'd" >&2; exit 1; }
OBJ_COUNT=$(pventer -c pvr-sdk find /storage/objects -mindepth 1 -maxdepth 1 | wc -l)
pventer -c pvr-sdk find /storage -not -name console.log | grep -v '^/storage/objects/[0-9a-f]' | sort
echo "object count: $OBJ_COUNT"
