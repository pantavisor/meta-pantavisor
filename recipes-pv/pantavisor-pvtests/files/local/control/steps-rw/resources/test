#!/bin/sh
#
# pv-ctrl step read + local revision write.
# Covers testplan-pvctrl.md Tests 5 (get state), 6 (show-progress),
# 30 (put state.json as a new local revision with a commit message).
#
# state.json is large and carries volatile object hashes, so we only assert
# its top-level key set; the new revision is verified by name in steps ls.

echo "== steps get 0 (top-level keys) =="
pvcontrol steps get 0 | jq -M 'keys' | tr -d '\r'

echo "== steps show-progress 0 =="
pvcontrol steps show-progress 0 | jq -M | tr -d '\r'

echo "== steps get current -> file =="
pvcontrol -f /tmp/state.json steps get current
echo "current state saved non-empty: $([ -s /tmp/state.json ] && echo yes || echo no)"

echo "== steps put new local revision =="
pvcontrol -m "test put" steps put /tmp/state.json locals/test-put-rev >/dev/null 2>&1
echo "steps put exit: $?"

echo "== steps ls names =="
pvcontrol steps ls | jq -M 'map(.name) | sort' | tr -d '\r'
