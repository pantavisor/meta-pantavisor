#!/bin/sh

source /usr/share/pantavisor/pvtest/utils

export CURL_CMD=curl

echo "== containers =="
pvcontrol containers ls | jq -M | tr -d '\r'
echo "== groups =="
pvcontrol groups ls | jq -M | tr -d '\r'
echo "== user-meta =="
pvcontrol usrmeta ls | jq -M | tr -d '\r'
echo "== device-meta =="
pvcontrol devmeta ls | jq -M 'del(.storage, .interfaces, .sysinfo, .time, .["pantavisor.uname"], .["pantavisor.cpumodel"], .["pantavisor.version"], .["pantavisor.arch"]) | to_entries | sort_by(.key) | from_entries' | tr -d '\r'
echo "object count > 0: $(pvcontrol objects ls | jq -M 'length > 0' | tr -d '\r')"
echo "== steps (current revision) =="
current_rev=$(pvcontrol devmeta ls | jq -M -r '.["pantavisor.revision"]' | tr -d '\r')
# No reset between tests: a rev installed as the device's first revision lands
# DONE (rollback point), but the same rev installed after other tests lands
# UPDATED (non-reboot) — position-dependent. Drop the rollback-point status/msg
# and keep the deterministic progress/retries.
pvcontrol steps ls | jq -M --arg r "$current_rev" 'map(select(.name == $r) | del(.date) | del(.progress.status, .progress["status-msg"]))' | tr -d '\r'
echo "== config =="
pvcontrol conf ls | jq -M | tr -d '\r'
